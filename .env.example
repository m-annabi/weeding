# PostgreSQL (Neon/Supabase) : URL poolée + URL directe (migrations)
DATABASE_URL="postgresql://user:password@host-pooler/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/db?sslmode=require"
ADMIN_PASSWORD="changez-moi"
AUTH_SECRET="generez-un-secret-aleatoire (openssl rand -hex 32)"
