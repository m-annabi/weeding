generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // URL poolée (pgbouncer) pour l'app ; URL directe pour les migrations/db push
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Group {
  id     String  @id @default(cuid())
  name   String  @unique
  guests Guest[]
}

model Guest {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  // Nombre maximum de personnes couvertes par cette invitation (invité inclus)
  maxGuests Int      @default(1)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  // Logement attribué par les mariés (kasbah ou logement annexe)
  lodgingId String?
  lodging   Lodging? @relation(fields: [lodgingId], references: [id], onDelete: SetNull)
  rsvp      Rsvp?
  createdAt DateTime @default(now())
}

model Lodging {
  id       String  @id @default(cuid())
  name     String  @unique
  // Nombre de places (personnes, pas chambres)
  capacity Int     @default(0)
  note     String?
  guests   Guest[]
}

model Rsvp {
  id            String        @id @default(cuid())
  guestId       String        @unique
  guest         Guest         @relation(fields: [guestId], references: [id], onDelete: Cascade)
  attending     Boolean
  email         String?
  phone         String?
  // Voyage — PLANE | CAR | ON_SITE
  arrivalMode        String?
  // Code aéroport (voir wedding.airports) : ESU | RAK | AGA
  arrivalAirport     String?
  arrivalDate        String? // YYYY-MM-DD
  arrivalTime        String? // HH:MM
  arrivalFlight      String?
  departureDate      String?
  departureTime      String?
  departureFlight    String?
  needsTransfer      Boolean @default(false)
  // KASBAH | OTHER
  accommodation      String?
  accommodationOther String?
  offersCarpool      Boolean       @default(false)
  comment       String?
  submittedAt   DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  participants  Participant[]
}

model Participant {
  id           String  @id @default(cuid())
  rsvpId       String
  rsvp         Rsvp    @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  // NONE | VEGETARIAN | VEGAN | HALAL | GLUTEN_FREE | OTHER (SQLite: pas d'enum Prisma)
  diet         String  @default("NONE")
  dietOther    String?
  allergies    String?
  childMenu    Boolean @default(false)
  specialNeeds String?
}
